BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id_here
AUTO_CAPTION=true
WHISPER_LANGUAGE=ru
WHISPER_MODEL=base
WHISPER_CPU_THREADS=2
MAX_CONCURRENT=4
TRANSCRIBE_CONCURRENT=1
RENDER_CONCURRENT=2
DATA_DIR=./data
LOG_DIR=./data
ENABLE_FILE_LOG=true
ALLOWED_UPDATES=message,callback_query
INVITE_ONLY=false
ALLOWED_USER_IDS=
MAX_VIDEO_DURATION=60
MAX_VIDEO_FILE_SIZE_MB=25
SQLITE_BACKUP_INTERVAL_HOURS=12
SQLITE_BACKUP_KEEP=14
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me

# Optional: set to enable webhook mode instead of polling
# WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PATH=/telegram/circle-bot
# WEBHOOK_HOST=127.0.0.1
# WEBHOOK_PORT=8088
# WEBHOOK_SECRET_TOKEN=replace_with_long_random_string
